# =========================
# Build directories
# =========================
build/
build-*/
cmake-build-*/
out/

# =========================
# CMake generated files
# =========================
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
CTestTestfile.cmake
Testing/
install_manifest.txt

# 如果 compile_commands.json 是生成在 build 目录里，会被 build*/ 忽略
# 如果你在项目根目录做了软链接，可以按需要决定是否忽略
# compile_commands.json

# =========================
# Binary / object files
# =========================
*.o
*.obj
*.a
*.so
*.so.*
*.dylib
*.dll
*.exe
*.out
*.app

# Executables without extension
main
echo_server
ping_pong
ping-pong

# =========================
# Logs
# =========================
*.log
logs/
log/
*.log.*
*.trace

# Async logging generated files
*.log.*
*_log
*.INFO
*.WARN
*.ERROR
*.FATAL

# =========================
# Core dumps / crash files
# =========================
core
core.*
*.core

# =========================
# Sanitizer output
# =========================
asan.*
tsan.*
lsan.*
ubsan.*
sanitizer.*
*.asan
*.tsan

# =========================
# Benchmark output
# =========================
bench_output/
benchmark_output/
results/tmp/
*.bench
*.perf
perf.data
perf.data.*

# =========================
# Editor / IDE
# =========================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# =========================
# Python cache, if scripts use Python
# =========================
__pycache__/
*.pyc

# =========================
# Temporary files
# =========================
tmp/
temp/
*.tmp